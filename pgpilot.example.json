{
  "listen": "127.0.0.1:6432",
  "primary": "127.0.0.1:55432",
  "replicas": ["127.0.0.1:55433", "127.0.0.1:55434"],
  "users": [
    {"name": "pgpilot", "password": "pgpilot"}
  ],
  "pool": {
    "mode": "session",
    "max_size": 10,
    "max_waiters": 100,
    "acquire_timeout": "5s",
    "idle_timeout": "5m"
  },
  "health": {
    "interval": "1s",
    "failure_threshold": 3,
    "base_backoff": "1s",
    "max_backoff": "30s"
  },
  "fencing": {
    "mode": "strict",
    "bounded_ms": 100
  },
  "routing": {
    "policy": "least-in-flight"
  }
}
